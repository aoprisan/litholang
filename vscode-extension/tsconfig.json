{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "out",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "litholang": ["../dist/index.d.ts"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}
