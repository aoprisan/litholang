{
  "Function Definition": {
    "prefix": "define",
    "body": [
      "define ${1:name}(${2:param}: ${3:Type}) -> ${4:ReturnType} as",
      "  $0",
      "end"
    ],
    "description": "Define a new function"
  },
  "Async Function Definition": {
    "prefix": "adefine",
    "body": [
      "async define ${1:name}(${2:param}: ${3:Type}) -> ${4:Result<ReturnType, Error>} as",
      "  $0",
      "end"
    ],
    "description": "Define an async function"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} has",
      "  ${2:field}: ${3:Type}",
      "end"
    ],
    "description": "Define a struct"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} is",
      "  ${2:Variant1}",
      "  ${3:Variant2}",
      "end"
    ],
    "description": "Define an enum"
  },
  "If-Then-Else": {
    "prefix": "if",
    "body": [
      "if ${1:condition} then",
      "  $0",
      "end"
    ],
    "description": "If-then block"
  },
  "If-Then-Else (with else)": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} then",
      "  $2",
      "else",
      "  $0",
      "end"
    ],
    "description": "If-then-else block"
  },
  "Match": {
    "prefix": "match",
    "body": [
      "match ${1:expr} on",
      "  case ${2:pattern} => ${3:result}",
      "  case _ => ${0:default}",
      "end"
    ],
    "description": "Pattern matching block"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:collection} do",
      "  $0",
      "end"
    ],
    "description": "For-in loop"
  },
  "Check Guard": {
    "prefix": "check",
    "body": [
      "check ${1:condition}",
      "  or return ${0:error_value}"
    ],
    "description": "Check guard with error return"
  },
  "Pipeline": {
    "prefix": "pipe",
    "body": [
      "${1:data}",
      "  |> ${2:transform}",
      "  |> ${0:collect}"
    ],
    "description": "Pipeline expression"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import ${1:Name} from \"${2:module}\""
    ],
    "description": "Import declaration"
  },
  "Purpose Annotation": {
    "prefix": "@purpose",
    "body": [
      "@purpose \"${1:description}\""
    ],
    "description": "Purpose annotation"
  },
  "Invariant Annotation": {
    "prefix": "@invariant",
    "body": [
      "@invariant \"${1:condition}\""
    ],
    "description": "Invariant annotation"
  },
  "Example Annotation": {
    "prefix": "@example",
    "body": [
      "@example \"${1:usage}\""
    ],
    "description": "Example annotation"
  },
  "Type Alias": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = ${0:Type}"
    ],
    "description": "Type alias"
  },
  "Extern Function": {
    "prefix": "extern",
    "body": [
      "extern define ${1:name}(${2:param}: ${3:Type}) -> ${4:ReturnType}",
      "  from \"${5:module}\"",
      "end"
    ],
    "description": "External function declaration (FFI)"
  },
  "Async Extern Function": {
    "prefix": "aextern",
    "body": [
      "extern async define ${1:name}(${2:param}: ${3:Type}) -> ${4:ReturnType}",
      "  from \"${5:module}\"",
      "end"
    ],
    "description": "Async external function declaration (FFI)"
  },
  "Try-Rescue": {
    "prefix": "try",
    "body": [
      "try",
      "  $1",
      "rescue ${2:err}",
      "  $0",
      "end"
    ],
    "description": "Try-rescue error handling block"
  },
  "Repeat While": {
    "prefix": "repeat",
    "body": [
      "repeat while ${1:condition} do",
      "  $0",
      "end"
    ],
    "description": "Repeat-while loop"
  },
  "Tuple Type": {
    "prefix": "tuple",
    "body": [
      "Tuple<${1:A}, ${2:B}>"
    ],
    "description": "Tuple type annotation"
  },
  "Match Tuple": {
    "prefix": "matcht",
    "body": [
      "match ${1:expr} on",
      "  case (${2:a}, ${3:b}) => ${4:result}",
      "  case (_, _) => ${0:default}",
      "end"
    ],
    "description": "Pattern match on a tuple"
  },
  "Tailrec Function": {
    "prefix": "tailrec",
    "body": [
      "@tailrec",
      "define ${1:name}(${2:param}: ${3:Type}, acc: ${4:Type}) -> ${5:ReturnType} as",
      "  check ${6:base_condition} or return acc",
      "  return ${1:name}(${7:next}, ${0:next_acc})",
      "end"
    ],
    "description": "Tail-recursive function with accumulator"
  },
  "Check Guard with Error": {
    "prefix": "checkerr",
    "body": [
      "check ${1:condition} or return err(\"${0:error message}\")"
    ],
    "description": "Check guard returning an error"
  }
}
