{
  "name": "litholang",
  "displayName": "LithoLang",
  "description": "Language support for LithoLang — syntax highlighting, diagnostics, hover, and completions",
  "version": "0.2.0",
  "publisher": "litholang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "litho",
    "litholang",
    "transpiler",
    "llm",
    "programming-language"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/litholang/litholang"
  },
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onLanguage:litho"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "litho",
        "aliases": [
          "LithoLang",
          "Litho",
          "litho"
        ],
        "extensions": [
          ".litho"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/litho-light.png",
          "dark": "./icons/litho-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "litho",
        "scopeName": "source.litho",
        "path": "./syntaxes/litho.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "litho",
        "path": "./snippets/litho.json"
      }
    ]
  }
}
