{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LithoLang",
  "scopeName": "source.litho",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-operator-word" },
    { "include": "#builtin-types" },
    { "include": "#builtin-functions" },
    { "include": "#function-definition" },
    { "include": "#struct-definition" },
    { "include": "#enum-definition" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-dash.litho",
      "match": "--.*$"
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.litho",
          "match": "(@\\w+)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "entity.other.attribute-name.litho" },
            "2": { "name": "string.quoted.double.litho" }
          }
        },
        {
          "name": "entity.other.attribute-name.litho",
          "match": "@\\w+"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.litho",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.litho",
          "match": "\\\\[\"\\\\nrt]"
        },
        {
          "name": "meta.interpolation.litho",
          "match": "\\{[^}]*\\}",
          "captures": {
            "0": { "name": "variable.other.interpolation.litho" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.litho",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.litho",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "booleans": {
      "name": "constant.language.boolean.litho",
      "match": "\\b(true|false)\\b"
    },
    "keywords-declaration": {
      "name": "keyword.declaration.litho",
      "match": "\\b(define|struct|enum|type|import|from|extern|export)\\b"
    },
    "keywords-control": {
      "name": "keyword.control.litho",
      "match": "\\b(if|then|else|for|in|do|match|on|case|return|check|end|async|await|repeat|while|try|rescue)\\b"
    },
    "keywords-operator-word": {
      "name": "keyword.operator.word.litho",
      "match": "\\b(and|or|not|is|as|has|with|where|each|all|self|of|by|collect)\\b"
    },
    "builtin-types": {
      "name": "support.type.litho",
      "match": "\\b(Text|Number|Boolean|Void|List|Map|Set|Maybe|Result|Tuple|Duration|Date|Timestamp)\\b"
    },
    "builtin-functions": {
      "name": "support.function.litho",
      "match": "\\b(ok|err|some|none|print|range|filter|map|sort|sum|first|last|skip|take|enumerate|zip|group|flatten|contains|length|to_text|to_number)\\b"
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(extern)\\s+(async\\s+)?(define)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.declaration.litho" },
            "2": { "name": "keyword.control.litho" },
            "3": { "name": "keyword.declaration.litho" },
            "4": { "name": "entity.name.function.litho" }
          }
        },
        {
          "match": "\\b(async\\s+)?(define)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.control.litho" },
            "2": { "name": "keyword.declaration.litho" },
            "3": { "name": "entity.name.function.litho" }
          }
        }
      ]
    },
    "struct-definition": {
      "match": "\\b(struct)\\s+([A-Z][a-zA-Z0-9]*)\\s+(has)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.litho" },
        "2": { "name": "entity.name.type.litho" },
        "3": { "name": "keyword.operator.word.litho" }
      }
    },
    "enum-definition": {
      "match": "\\b(enum)\\s+([A-Z][a-zA-Z0-9]*)\\s+(is)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.litho" },
        "2": { "name": "entity.name.type.litho" },
        "3": { "name": "keyword.operator.word.litho" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.litho",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.litho",
          "match": "->"
        },
        {
          "name": "keyword.operator.fat-arrow.litho",
          "match": "=>"
        },
        {
          "name": "keyword.operator.propagate.litho",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.range.litho",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.comparison.litho",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.litho",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.litho",
          "match": "(?<![=!<>])=(?!=)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.litho",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.litho",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.litho",
          "match": "\\."
        },
        {
          "name": "punctuation.bracket.round.litho",
          "match": "[()]"
        },
        {
          "name": "punctuation.bracket.square.litho",
          "match": "[\\[\\]]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.constant.litho",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        },
        {
          "name": "variable.other.litho",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
